{
  "openapi": "3.0.1",
  "info": {
    "title": "OpenMRS Clinical Simulator",
    "version": "v1"
  },
  "paths": {
    "/api/seed/status": {
      "get": {
        "tags": [
          "Seed"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/seed/run": {
      "post": {
        "tags": [
          "Seed"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RunRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RunRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/seed/progress/{runId}": {
      "get": {
        "tags": [
          "Seed"
        ],
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/seed/clear": {
      "delete": {
        "tags": [
          "Seed"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RunRequest": {
        "type": "object",
        "properties": {
          "step": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}