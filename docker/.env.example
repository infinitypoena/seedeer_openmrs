# URL de la REST API de OpenMRS (sin trailing slash)
# En Windows/Mac con OpenMRS local: host.docker.internal
# En Linux con OpenMRS local: 172.17.0.1 (IP del gateway Docker)
OPENMRS_URL=http://host.docker.internal/openmrs/ws/rest/v1

# Credenciales de OpenMRS
OPENMRS_USERNAME=admin
OPENMRS_PASSWORD=TU_PASSWORD_AQUI

# Parámetros de simulación
# Validación (1 semana, volumen bajo):
#   SIM_START=2023-01-01  SIM_END=2023-01-08  SIM_VOLUME=8
# Producción (2 años, volumen real):
SIM_START=2023-01-01
SIM_END=2024-12-31
SIM_VOLUME=40
